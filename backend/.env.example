# ─────────────────────────────────────────────
# CrisisLens Backend — Environment Variables
# Copy this file to .env and fill in all values
# NEVER commit .env to Git
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
# Render PostgreSQL connection string
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=

# ── Redis ─────────────────────────────────────
# Render Redis connection string
# Format: redis://USER:PASSWORD@HOST:PORT
REDIS_URL=

# ── NewsAPI ───────────────────────────────────
# Register at: https://newsapi.org/register
# Used for: Al Jazeera English, BBC, Reuters, AP
NEWSAPI_KEY=

# ── New York Times ────────────────────────────
# Register at: https://developer.nytimes.com
# Enable: Article Search API, Top Stories API, Times Wire API
NYT_API_KEY=

# ── Telegram MTProto ──────────────────────────
# Get credentials at: https://my.telegram.org/apps
# Used for: AJ+ Arabic, AJ+ English, BNO News, War Monitor
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ── NLP Thresholds ────────────────────────────
# Minimum cosine similarity to consider two articles as a candidate pair
# Range: 0.0 – 1.0 | Default: 0.65
COSINE_SIMILARITY_THRESHOLD=0.65

# Minimum NLI confidence to record a detected conflict
# Range: 0.0 – 1.0 | Default: 0.70
NLI_CONFIDENCE_THRESHOLD=0.70

# ── Environment ───────────────────────────────
# Options: development | production
APP_ENV=development